{
  "name": "matrix-minimal",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "lint": "eslint server.js",
    "lint:fix": "eslint server.js --fix",
    "format": "prettier --write server.js",
    "format:check": "prettier --check server.js",
    "test:ci": "npm run lint && npm run format:check && node -e \"require('./server.js')\" && process.exit(0)"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5"
  }
}
